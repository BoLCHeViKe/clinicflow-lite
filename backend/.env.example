# Servidor
PORT=3001
NODE_ENV=development

# Base de datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password_segura
DB_NAME=clinicflow_db
DB_PORT=3306

# JWT — usa una clave aleatoria de al menos 32 caracteres
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_aleatoria_de_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# URL del frontend (CORS) — separar por comas si hay varios orígenes
FRONTEND_URL=http://localhost:4200
